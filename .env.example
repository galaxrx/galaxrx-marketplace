# Database — Supabase PostgreSQL
# DATABASE_URL: app runtime. On Vercel use Supabase POOLED / transaction URL (often port 6543).
# DIRECT_URL: Prisma migrations (migrate deploy). Must be DIRECT host (db.*.supabase.co port 5432), not the pooler.
# Local dev with one connection: set DIRECT_URL to the same value as DATABASE_URL.
# Add ?connect_timeout=5 to avoid hanging if DB is unreachable.
DATABASE_URL="postgresql://user:password@host:5432/database?schema=public&connect_timeout=5"
DIRECT_URL="postgresql://user:password@host:5432/database?schema=public&connect_timeout=5"

# NextAuth — must match the URL you use in the browser (e.g. if you open http://127.0.0.1:3000, use that here)
NEXTAUTH_URL="http://127.0.0.1:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
# Set to true so sign-in/sign-out work when browser URL and NEXTAUTH_URL host differ (e.g. localhost vs 127.0.0.1)
AUTH_TRUST_HOST="true"

# Public support / contact email (footer, mailto, transactional copy). Optional; defaults in code to galaxrx.team@gmail.com.
NEXT_PUBLIC_PLATFORM_EMAIL="galaxrx.team@gmail.com"
# Display number for Contact + footer (tel: derived automatically). Default in code: +61 402 098 652 (+61402098652).
# NEXT_PUBLIC_PLATFORM_PHONE="+61 402 098 652"
# Defaults in code: instagram.com/galaxrx, linkedin.com/company/galaxrx
# NEXT_PUBLIC_INSTAGRAM_URL="https://www.instagram.com/galaxrx/"
# NEXT_PUBLIC_LINKEDIN_URL="https://www.linkedin.com/company/galaxrx/"

# PBS API (sync:pbs)
PBS_API_BASE=https://data-api.health.gov.au/pbs/api/v3
PBS_PUBLIC_KEY=

# Medipim AU API V4 (sync:medipim) — get key/secret from info@medipim.com
MEDIPIM_API_BASE=https://api.au.medipim.com
MEDIPIM_API_KEY=
MEDIPIM_API_SECRET=

# Uploadthing
UPLOADTHING_SECRET=
UPLOADTHING_APP_ID=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Set to "true" to enable direct charges (seller as MoR). Default is destination charges.
# Only enable after testing in Stripe test mode with connected accounts.
STRIPE_USE_DIRECT_CHARGES=false

# After a seller accepts a price offer, the listing stays "pending" for other buyers until this many hours pass without checkout (default 24).
# NEGOTIATION_ACCEPTANCE_HOLD_HOURS=24

# Australia Post — Postage Assessment Calculator (PAC) for domestic parcel rates
# Get key: https://developers.auspost.com.au/apis/pacpcs-registration
AUSPOST_API_KEY=

# Barcode Lookup API (used by Sell > Barcode scanner to auto-fill product fields)
BARCODELOOKUP_API_KEY=

# Register of Pharmacies API — verify pharmacist by registration code during sign-up
# For API NSW (api.nsw.gov.au account): set BASE_URL (e.g. https://api.nsw.gov.au/) + API_KEY + API_SECRET
#   (or AUTH_HEADER = "Basic <base64(key:secret)>"). App gets OAuth token from api.onegov.nsw.gov.au and calls Verify.
REGISTER_OF_PHARMACIES_API_BASE_URL=
REGISTER_OF_PHARMACIES_API_KEY=
REGISTER_OF_PHARMACIES_API_SECRET=
REGISTER_OF_PHARMACIES_AUTH_HEADER=
# Optional: REGISTER_OF_PHARMACIES_CODE_PARAM=registrationNumber (default)
# For Data.NSW CKAN only: set RESOURCE_ID + VERIFY_PATH to full data.nsw.gov.au URL
# REGISTER_OF_PHARMACIES_RESOURCE_ID=...
# REGISTER_OF_PHARMACIES_VERIFY_PATH=https://data.nsw.gov.au/data/api/action/datastore_search

# Resend (required for enquiry form + transactional mail)
RESEND_API_KEY=
EMAIL_FROM="GalaxRX <noreply@galaxrx.com.au>"
# Optional: where /api/contact/enquiry delivers (defaults to NEXT_PUBLIC_PLATFORM_EMAIL)
# CONTACT_ENQUIRY_TO=galaxrx.team@gmail.com
