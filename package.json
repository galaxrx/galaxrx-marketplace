{
  "name": "galaxrx-marketplace",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev-open.js",
    "dev:next": "next dev -H 127.0.0.1 -p 3002",
    "dev:clean": "node scripts/clean-dev.js",
    "dev:alt": "set PORT=3003 && node scripts/dev-open.js",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate:create": "node scripts/create-migration.js",
    "db:set-admin": "ts-node -P tsconfig.scripts.json scripts/set-admin.ts",
    "db:create-admin": "ts-node -P tsconfig.scripts.json scripts/create-admin.ts",
    "db:set-password": "ts-node -P tsconfig.scripts.json scripts/set-password.ts",
    "db:delete-pharmacy": "ts-node -P tsconfig.scripts.json scripts/delete-pharmacy.ts",
    "db:add-listing-columns": "ts-node -P tsconfig.scripts.json scripts/add-listing-columns.ts",
    "db:add-pharmacy-lat-lng": "ts-node -P tsconfig.scripts.json scripts/add-pharmacy-lat-lng.ts",
    "db:geocode-pharmacies": "ts-node -P tsconfig.scripts.json scripts/geocode-pharmacies.ts",
    "db:run-one-accepted-migration": "ts-node -P tsconfig.scripts.json scripts/run-one-accepted-migration.ts",
    "db:seed": "prisma db seed",
    "sync:pbs": "ts-node -P tsconfig.scripts.json scripts/sync-pbs.ts",
    "sync:pbs-csv": "ts-node -P tsconfig.scripts.json scripts/sync-pbs-csv.ts",
    "sync:medipim": "ts-node -P tsconfig.scripts.json scripts/sync-medipim.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.2",
    "@stripe/react-stripe-js": "^2.8.1",
    "@stripe/stripe-js": "^4.8.0",
    "@zxing/library": "^0.20.0",
    "bcryptjs": "^2.4.3",
    "date-fns": "^4.1.0",
    "framer-motion": "^11.11.17",
    "geolib": "^3.3.4",
    "next": "14.2.24",
    "next-auth": "^4.24.10",
    "open": "^10.0.0",
    "pdfkit": "^0.17.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^4.0.1",
    "sonner": "^1.7.0",
    "stripe": "^17.2.0",
    "uploadthing": "^7.3.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@prisma/client": "^5.22.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.9.0",
    "@types/pdfkit": "^0.17.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "dotenv": "^17.3.1",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.18",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.15",
    "tailwindcss-animate": "^1.0.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\",\"moduleResolution\":\"node\"} prisma/seed.ts"
  }
}
